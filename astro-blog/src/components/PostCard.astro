---
interface Props {
  title: string;
  url: string;
  date: Date;
  cover?: string;
  excerpt?: string;
  tags?: string[];
}

const { title, url, date, cover, excerpt, tags = [] } = Astro.props;
const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'short', year: 'numeric',
});
---

<div class="post-card">
  <div class="post-card-thumb">
    {cover ? (
      <img src={cover} alt={title} loading="lazy" />
    ) : (
      <span aria-hidden="true">✦</span>
    )}
  </div>
  <div class="post-card-body">
    <div class="post-card-date">{formattedDate}</div>
    <a href={url} class="post-card-title">{title}</a>
    {excerpt && <p class="post-card-excerpt">{excerpt}</p>}
    {tags.length > 0 && (
      <div class="post-card-tags">
        {tags.map(tag => (
          <a href={`/tags#${tag}`} class="tag-chip">{tag}</a>
        ))}
      </div>
    )}
  </div>
</div>
